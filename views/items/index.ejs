<%- include("../partials/header") %>
<main>

<div class="page-header">
  <h2>All Items</h2>
  <a href="/items/new" class="btn btn-primary">+ New Item</a>
</div>

<% if (items.length === 0) { %>
  <p class="empty">No items yet. Add one to get started!</p>
<% } else { %>
  <table>
    <thead>
      <tr><th>Name</th><th>Category</th><th>Price</th><th>Stock</th></tr>
    </thead>
    <tbody>
      <% items.forEach(item => { %>
        <tr>
          <td><a href="/items/<%= item.id %>"><%= item.name %></a></td>
          <td><a href="/categories/<%= item.category_id %>"><%= item.category_name %></a></td>
          <td>$<%= parseFloat(item.price).toFixed(2) %></td>
          <td class="stock <%= item.quantity < 10 ? 'low' : '' %>"><%= item.quantity %></td>
        </tr>
      <% }) %>
    </tbody>
  </table>
<% } %>

<%- include("../partials/footer") %>