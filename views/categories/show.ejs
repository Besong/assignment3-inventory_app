<%- include("../partials/header") %>
<main>

<div class="detail-header">
  <h2><%= category.name %></h2>
  <% if (category.description) { %>
    <p style="color: var(--muted); margin-top: 0.25rem; margin-bottom: 0.5rem;"><%= category.description %></p>
  <% } %>
  <div class="actions">
    <a href="/categories/<%= category.id %>/edit" class="btn btn-outline">Edit</a>
    <a href="/items/new?category_id=<%= category.id %>" class="btn btn-primary">+ Add Item</a>
  </div>
</div>

<% if (typeof error !== 'undefined' && error) { %>
  <div class="error"><%= error %></div>
<% } %>

<% if (items.length === 0) { %>
  <p class="empty">No items in this category yet.</p>
<% } else { %>
  <table>
    <thead>
      <tr><th>Name</th><th>Price</th><th>Stock</th></tr>
    </thead>
    <tbody>
      <% items.forEach(item => { %>
        <tr>
          <td><a href="/items/<%= item.id %>"><%= item.name %></a></td>
          <td>$<%= parseFloat(item.price).toFixed(2) %></td>
          <td class="stock <%= item.quantity < 10 ? 'low' : '' %>"><%= item.quantity %></td>
        </tr>
      <% }) %>
    </tbody>
  </table>
<% } %>

<div class="delete-section">
  <details>
    <summary>Delete this category</summary>
    <p style="margin-top:0.5rem; color: var(--muted); font-size: 0.9rem;">
      This will permanently delete "<%= category.name %>" and all its items. Enter the admin password to confirm.
    </p>
    <form action="/categories/<%= category.id %>/delete" method="POST" class="delete-form">
      <div class="form-group">
        <input type="password" name="admin_password" placeholder="Admin password" required>
      </div>
      <button type="submit" class="btn btn-danger">Delete Category</button>
    </form>
  </details>
</div>

<%- include("../partials/footer") %>